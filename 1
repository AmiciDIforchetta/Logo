<!DOCTYPE html>
<html>
<head>
  <title>Menu Ristorante</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #fafafa;
      text-align: center;
    }

    .container {
      padding: 20px;
    }

    img.logo {
      width: 180px;
      margin: 20px 0;
    }

    h1 {
      margin-bottom: 10px;
    }

    h2 {
      margin-top: 30px;
      color: #333;
      border-bottom: 1px solid #ddd;
      padding-bottom: 5px;
    }

    .item {
      display: flex;
      justify-content: space-between;
      margin: 8px 0;
      padding: 0 10px;
    }

    .price {
      font-weight: bold;
    }
  </style>
</head>

<body>

  <div class="container">

    <!-- LOGO -->
    <img src="photo-output.png" class="logo">

    <h1>Menu</h1>

    <h2>Antipasti</h2>
    <div class="item">
      <span>Bruschetta</span>
      <span class="price">5€</span>
    </div>

    <h2>Primi</h2>
    <div class="item">
      <span>Pasta al pomodoro</span>
      <span class="price">8€</span>
    </div>

    <h2>Secondi</h2>
    <div class="item">
      <span>Bistecca</span>
      <span class="price">15€</span>
    </div>

    <h2>Dolci</h2>
    <div class="item">
      <span>Tiramisù</span>
      <span class="price">5€</span>
    </div>

  </div>

</body>
</html>
